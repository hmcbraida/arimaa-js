{
  "name": "arimaatic",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:docker": "VITE_API_URL=http://localhost:8080 vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "build:nocheck": "vite build",
    "server": "bun run src/server/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/server/persistence/runMigrations.ts",
    "test": "bun test src/",
    "test:ui": "playwright test",
    "lint": "eslint . && biome check .",
    "format": "biome check --write ."
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/websocket": "^11.2.0",
    "@tanstack/react-router": "^1.169.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fastify-type-provider-zod": "^6.1.0",
    "jose": "^6.2.3",
    "lucide-react": "^0.468.0",
    "nats": "^2.29.3",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@eslint/js": "^9.17.0",
    "@happy-dom/global-registrator": "^20.9.0",
    "@j178/prek": "^0.3.13",
    "@playwright/test": "^1.49.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "bun-types": "^1.3.13",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "happy-dom": "^20.9.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vite": "^6.0.5"
  }
}
